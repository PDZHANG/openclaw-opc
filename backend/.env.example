PORT=4000
DATABASE_PATH=../data/db.sqlite
OPENCLAW_PATH=~/.openclaw
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=
CORS_ORIGIN=http://localhost:3000

# OpenClaw WebSocket RPC 配置 (可选)
# 设置为 true 启用 WebSocket RPC 模式，默认为 false (使用 HTTP API)
OPENCLAW_USE_WEBSOCKET_RPC=false
# WebSocket 网关地址
OPENCLAW_GATEWAY_WS_URL=ws://localhost:18789
# 允许不安全的 TLS 连接 (仅用于开发)
OPENCLAW_ALLOW_INSECURE_TLS=false
# 禁用设备配对，使用控制 UI 模式 (需要设置正确的 origin)
OPENCLAW_DISABLE_DEVICE_PAIRING=false
# 自定义 origin (用于 control_ui 模式，例如 http://localhost:18789)
OPENCLAW_GATEWAY_WS_ORIGIN=
